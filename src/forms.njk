---
layout: base.njk
title: "Forms & Documents — Town of Florida, MA"
description: "Town of Florida, MA — Forms, documents, FAQ, and town bylaws."
navKey: forms
permalink: forms.html
---

  <div class="page-header">
    <div class="container">
      <p class="page-header__eyebrow">Town of Florida, MA</p>
      <h1 class="page-header__title">Forms &amp; Documents</h1>
      <p class="page-header__desc">Downloadable forms, town bylaws, and answers to common Town Hall questions.</p>
    </div>
  </div>

  <div class="breadcrumb container">
    <a href="/">Home</a><span>›</span> Forms &amp; Documents
  </div>

  <section class="section">
    <div class="container">

      <div style="text-align:center; margin-bottom:40px;">
        <p class="section-eyebrow" style="margin: 0 auto 12px;">Downloadable PDFs</p>
        <h2 class="section-title">Town Forms &amp; Applications</h2>
        <p class="section-sub">Click any form to open or download. Contact Town Hall if you need assistance completing a form.</p>
      </div>

      <!-- FORMS GRID — driven by _data/forms.js -->
      <div class="forms-grid">
        {% for form in forms.forms %}
        <div class="form-card">
          <div class="form-card__icon">
            {% if form.iconType == "home" %}
            <svg viewBox="0 0 24 24" fill="none" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"><path d="M3 9l9-7 9 7v11a2 2 0 01-2 2H5a2 2 0 01-2-2z"/><polyline points="9 22 9 12 15 12 15 22"/></svg>
            {% elif form.iconType == "zap" %}
            <svg viewBox="0 0 24 24" fill="none" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"><polygon points="13 2 3 14 12 14 11 22 21 10 12 10 13 2"/></svg>
            {% elif form.iconType == "shield" %}
            <svg viewBox="0 0 24 24" fill="none" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
            {% else %}
            <svg viewBox="0 0 24 24" fill="none" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"><path d="M14.7 6.3a1 1 0 000 1.4l1.6 1.6a1 1 0 001.4 0l3.77-3.77a6 6 0 01-7.94 7.94l-6.91 6.91a2.12 2.12 0 01-3-3l6.91-6.91a6 6 0 017.94-7.94l-3.76 3.76z"/></svg>
            {% endif %}
          </div>
          <div class="form-card__title">{{ form.title }}</div>
          <div class="form-card__desc">{{ form.description }}</div>
          <a href="{{ form.url }}" target="_blank" rel="noopener" class="btn btn--primary btn--sm">Open PDF</a>
        </div>
        {% endfor %}
      </div>

      <!-- TOWN BYLAWS & ZONING BYLAWS -->
      <div style="margin-top:56px;">
        <div style="text-align:center; margin-bottom:32px;">
          <p class="section-eyebrow" style="margin: 0 auto 12px;">Official Documents</p>
          <h2 class="section-title" id="bylaws">Town Bylaws &amp; Zoning Bylaws</h2>
          <p class="section-sub">Current adopted bylaws for the Town of Florida. ODT files can be opened in Microsoft Word, Google Docs, or LibreOffice.</p>
        </div>
        <div class="minutes-grid">
          <div class="minutes-card">
            <div class="minutes-card__year">2025</div>
            <div class="minutes-card__title">General Bylaw Approval 2025</div>
            <a href="https://files.cdn-files-a.com/uploads/2365528/normal_6920b1f07cd4a.pdf" target="_blank" rel="noopener" class="minutes-card__link">Open PDF →</a>
          </div>
          <div class="minutes-card">
            <div class="minutes-card__year">2025</div>
            <div class="minutes-card__title">Town Bylaws 2025</div>
            <a href="https://files.cdn-files-a.com/uploads/2365528/normal_6920bbbd0e86e.odt" target="_blank" rel="noopener" class="minutes-card__link">Open (.odt) →</a>
          </div>
          <div class="minutes-card">
            <div class="minutes-card__year">2025</div>
            <div class="minutes-card__title">Zoning Bylaws 2025</div>
            <a href="https://files.cdn-files-a.com/uploads/2365528/normal_692a0ba96b10a.odt" target="_blank" rel="noopener" class="minutes-card__link">Open (.odt) →</a>
          </div>
        </div>
      </div>

      <!-- ANSWERS TO COMMON TOWN HALL QUESTIONS -->
      <div style="margin-top:56px; margin-bottom:48px;">
        <div style="text-align:center; margin-bottom:32px;">
          <p class="section-eyebrow" style="margin: 0 auto 12px;">Helpful Information</p>
          <h2 class="section-title" id="faq">Answers to Common Town Hall Questions</h2>
          <p class="section-sub">A guide to frequently asked questions about Town Hall services, permits, and procedures.</p>
        </div>
        <div style="text-align:center;">
          <a href="https://files.cdn-files-a.com/uploads/2365528/normal_69f0fd0249e1e.docx" target="_blank" rel="noopener" class="btn btn--primary">Open Document →</a>
        </div>
      </div>

    </div>
  </section>
